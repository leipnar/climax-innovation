# Directus Configuration
# Copy this file to .env and update the values

# Security keys (generate random strings for production)
DIRECTUS_KEY=your-32-char-random-key-here
DIRECTUS_SECRET=your-32-char-random-secret-here

# Admin credentials
ADMIN_EMAIL=admin@climaxinnovation.com
ADMIN_PASSWORD=YourSecurePassword123!

# Database configuration (for Hostinger MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=u493946172_directus
DB_USER=u493946172_directus_user
DB_PASSWORD=YourDbPassword

# Directus URL
PUBLIC_URL=https://cms.climaxinnovation.com

# Email configuration
EMAIL_FROM=noreply@climaxinnovation.com
EMAIL_TRANSPORT=smtp
EMAIL_SMTP_HOST=smtp.hostinger.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=info@climaxinnovation.com
EMAIL_SMTP_PASSWORD=YourEmailPassword
