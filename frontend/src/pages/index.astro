---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import Services from '../components/Services.astro';
import Features from '../components/Features.astro';
import Testimonials from '../components/Testimonials.astro';
import CTA from '../components/CTA.astro';
import { getServices, getTestimonials } from '../lib/drupal';

const services = await getServices();
const testimonials = await getTestimonials();
---

<Layout title="Home">
  <Header />
  <main>
    <Hero
      subtitle="Building a Smarter Future"
      title="Transform Your Construction Projects with IoT, AI & Data Analytics"
      description="Climax Innovation delivers cutting-edge technology solutions for safer, smarter, and more sustainable construction operations."
      primaryCta={{ text: 'Get Started', href: '/contact' }}
      secondaryCta={{ text: 'Our Services', href: '/services' }}
    />
    <Services services={services} />
    <Features />
    <Testimonials testimonials={testimonials} />
    <CTA />
  </main>
  <Footer />
</Layout>
