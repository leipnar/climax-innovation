---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const posts = [
  {
    slug: 'technology-insights-building-smarter-future',
    title: 'Technology Insights: Building a Smarter Future',
    excerpt: 'How IoT, AI, and Data Analytics are Transforming Construction',
    date: '2024-01-15',
    author: 'Climax Team',
    category: 'Technology',
    image: null
  },
  {
    slug: 'project-management-insights',
    title: 'Project Management: Insights into Effective Project Management Strategies',
    excerpt: 'Learn the key strategies for managing construction projects effectively.',
    date: '2024-01-10',
    author: 'Climax Team',
    category: 'Management',
    image: null
  },
  {
    slug: 'safety-and-compliance',
    title: 'Safety and Compliance: Building a Culture of Well-Being on Construction Sites',
    excerpt: 'Essential practices for maintaining safety standards on construction sites.',
    date: '2024-01-05',
    author: 'Climax Team',
    category: 'Safety',
    image: null
  },
];

const categories = ['All', 'Technology', 'Management', 'Safety'];
---

<Layout title="Blog">
  <Header />
  <main>
    <section class="pt-32 pb-20 bg-gradient-to-br from-slate-50 via-blue-50 to-indigo-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl">
          <p class="text-blue-600 font-semibold tracking-wide uppercase text-sm mb-4">
            Blog
          </p>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-gray-900 mb-6">
            Insights & Updates
          </h1>
          <p class="text-lg text-gray-600 leading-relaxed">
            Stay up to date with the latest trends, insights, and news in construction 
            technology and innovation.
          </p>
        </div>
      </div>
    </section>

    <section class="py-20 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-wrap gap-3 mb-12">
          {categories.map((category) => (
            <button
              class={`px-4 py-2 rounded-full font-medium transition-colors ${category === 'All' ? 'bg-blue-600 text-white' : 'bg-gray-100 text-gray-600 hover:bg-gray-200'}`}
            >
              {category}
            </button>
          ))}
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {posts.map((post) => (
            <article class="bg-white border border-gray-100 rounded-2xl overflow-hidden hover:shadow-lg transition-shadow">
              <div class="aspect-video bg-gradient-to-br from-blue-100 to-indigo-100 flex items-center justify-center">
                {post.image ? (
                  <img src={post.image} alt={post.title} class="w-full h-full object-cover" />
                ) : (
                  <svg class="w-16 h-16 text-blue-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
                  </svg>
                )}
              </div>
              <div class="p-6">
                <div class="flex items-center gap-3 mb-3">
                  <span class="text-xs font-medium text-blue-600 bg-blue-50 px-2 py-1 rounded">
                    {post.category}
                  </span>
                  <span class="text-xs text-gray-500">
                    {new Date(post.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                  </span>
                </div>
                <h2 class="text-xl font-semibold text-gray-900 mb-2 line-clamp-2">
                  <a href={`/blog/${post.slug}`} class="hover:text-blue-600 transition-colors">
                    {post.title}
                  </a>
                </h2>
                <p class="text-gray-600 text-sm mb-4 line-clamp-2">
                  {post.excerpt}
                </p>
                <a
                  href={`/blog/${post.slug}`}
                  class="inline-flex items-center text-blue-600 font-medium text-sm hover:text-blue-700"
                >
                  Read More
                  <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                  </svg>
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
