---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Dashboard">
  <div class="min-h-screen bg-gray-50 pt-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <div class="bg-white rounded-2xl shadow-sm p-8">
        <div class="flex items-center justify-between mb-8">
          <div>
            <h1 class="text-2xl font-bold text-gray-900">Dashboard</h1>
            <p class="text-gray-600">Welcome to your Climax Innovation portal</p>
          </div>
          <a
            href="/api/logout.php"
            class="px-4 py-2 text-gray-600 hover:text-gray-800 border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors"
          >
            Sign Out
          </a>
        </div>

        <div class="grid md:grid-cols-3 gap-6 mb-8">
          <div class="bg-gradient-to-br from-amber-500 to-amber-600 rounded-xl p-6 text-white">
            <h3 class="text-lg font-medium mb-2">Active Projects</h3>
            <p class="text-4xl font-bold">12</p>
          </div>
          <div class="bg-gradient-to-br from-gray-700 to-gray-800 rounded-xl p-6 text-white">
            <h3 class="text-lg font-medium mb-2">Team Members</h3>
            <p class="text-4xl font-bold">8</p>
          </div>
          <div class="bg-gradient-to-br from-amber-400 to-amber-500 rounded-xl p-6 text-white">
            <h3 class="text-lg font-medium mb-2">Completed Tasks</h3>
            <p class="text-4xl font-bold">156</p>
          </div>
        </div>

        <div class="bg-gray-50 rounded-xl p-6">
          <h2 class="text-xl font-semibold text-gray-900 mb-4">Quick Actions</h2>
          <div class="grid md:grid-cols-4 gap-4">
            <a href="/api/drupal-login.php?destination=/cms/web/node/add/service" class="bg-white p-4 rounded-lg border border-gray-200 hover:border-amber-300 hover:shadow-sm transition-all text-center">
              <svg class="w-8 h-8 mx-auto mb-2 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
              </svg>
              <span class="text-gray-700 font-medium">Add Service</span>
            </a>
            <a href="/api/drupal-login.php?destination=/cms/web/node/add/testimonial" class="bg-white p-4 rounded-lg border border-gray-200 hover:border-amber-300 hover:shadow-sm transition-all text-center">
              <svg class="w-8 h-8 mx-auto mb-2 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" />
              </svg>
              <span class="text-gray-700 font-medium">Add Testimonial</span>
            </a>
            <a href="/api/drupal-login.php?destination=/cms/web/admin/content" class="bg-white p-4 rounded-lg border border-gray-200 hover:border-amber-300 hover:shadow-sm transition-all text-center">
              <svg class="w-8 h-8 mx-auto mb-2 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
              <span class="text-gray-700 font-medium">Manage Content</span>
            </a>
            <a href="/api/drupal-login.php?destination=/cms/web/admin" class="bg-white p-4 rounded-lg border border-gray-200 hover:border-amber-300 hover:shadow-sm transition-all text-center">
              <svg class="w-8 h-8 mx-auto mb-2 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              <span class="text-gray-700 font-medium">CMS Admin</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>
