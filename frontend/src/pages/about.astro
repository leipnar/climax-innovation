---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CTA from '../components/CTA.astro';

const values = [
  {
    title: 'Innovation',
    description: 'We continuously push the boundaries of what is possible in construction technology.',
    icon: '💡'
  },
  {
    title: 'Safety',
    description: 'Every solution we build prioritizes the safety of workers and communities.',
    icon: '🛡️'
  },
  {
    title: 'Sustainability',
    description: 'We are committed to reducing the environmental impact of construction projects.',
    icon: '🌱'
  },
  {
    title: 'Excellence',
    description: 'We deliver exceptional quality in every project we undertake.',
    icon: '⭐'
  },
];

const milestones = [
  { year: '2019', title: 'Founded', description: 'Climax Innovation was established with a vision to transform construction.' },
  { year: '2020', title: 'First Platform Launch', description: 'Released our initial IoT monitoring solution.' },
  { year: '2022', title: 'AI Integration', description: 'Introduced AI-powered predictive analytics.' },
  { year: '2024', title: 'Global Expansion', description: 'Expanded to serve clients across 20+ countries.' },
];

const team = [
  {
    name: 'Emad Rezaeian',
    role: 'CEO',
    image: 'https://old.climaxinnovation.com/wp-content/uploads/elementor/thumbs/emad-rjjnsl58fwtl6q34zpwlfwlwpq2dtpm8bsujloawow.jpg',
    linkedin: 'http://linkedin.com/in/emad-rezaeian-53949376'
  },
  {
    name: 'Rasool Askari',
    role: 'HR and Administrative Manager',
    image: 'https://old.climaxinnovation.com/wp-content/uploads/elementor/thumbs/Rasol-rjjnsl58fwtl6q34zpwlfwlwpq2dtpm8bsujloawow.jpg',
    linkedin: 'https://www.linkedin.com/in/rasool-askari-1ab944288'
  },
  {
    name: 'Mojtaba Khashayarfard',
    role: 'Marketing and Commercial Manager',
    image: 'https://old.climaxinnovation.com/wp-content/uploads/elementor/thumbs/Mojtaba-rjjnsl58fwtl6q34zpwlfwlwpq2dtpm8bsujloawow.jpg',
    linkedin: 'https://www.linkedin.com/in/mojtaba-khashayar-fard-402a3a8b'
  },
  {
    name: 'Mehrdad Habibi',
    role: 'Technical Manager',
    image: 'https://old.climaxinnovation.com/wp-content/uploads/elementor/thumbs/Mehrdad-rjjnsl58fwtl6q34zpwlfwlwpq2dtpm8bsujloawow.jpg',
    linkedin: 'http://linkedin.com/in/mehrdad-habibi-b4725a279'
  },
];
---

<Layout title="About Us">
  <Header />
  <main>
    <section class="pt-32 pb-20 relative overflow-hidden">
      <div class="absolute inset-0">
        <img 
          src="https://images.unsplash.com/photo-1504307651254-35680f356dfd?w=1200&q=75&auto=format" 
          srcset="https://images.unsplash.com/photo-1504307651254-35680f356dfd?w=800&q=75&auto=format 800w,
                  https://images.unsplash.com/photo-1504307651254-35680f356dfd?w=1200&q=75&auto=format 1200w,
                  https://images.unsplash.com/photo-1504307651254-35680f356dfd?w=1920&q=80&auto=format 1920w"
          sizes="100vw"
          alt="" 
          class="w-full h-full object-cover"
          loading="eager"
          width="1920"
          height="1080"
        />
        <div class="absolute inset-0 bg-gradient-to-r from-slate-900/90 via-slate-900/70 to-slate-900/50"></div>
      </div>
      <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl">
          <p class="text-amber-400 font-semibold tracking-wide uppercase text-sm mb-4">
            About Us
          </p>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6">
            Building a Smarter Future
          </h1>
          <p class="text-lg text-gray-300 leading-relaxed">
            Climax Innovation is at the forefront of transforming the construction industry 
            through cutting-edge technology. We combine IoT, AI, and data analytics to create 
            safer, smarter, and more sustainable construction operations.
          </p>
        </div>
      </div>
    </section>

    <section class="py-20 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <div>
            <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">
              Our Mission
            </h2>
            <p class="text-lg text-gray-600 mb-6">
              We believe that technology can revolutionize how construction projects are managed. 
              Our mission is to provide innovative solutions that enhance safety, improve efficiency, 
              and reduce environmental impact across the construction industry.
            </p>
            <p class="text-lg text-gray-600">
              With decades of combined experience in construction and technology, our team 
              understands the unique challenges faced by the industry and delivers practical, 
              results-driven solutions.
            </p>
          </div>
          <div class="rounded-2xl overflow-hidden shadow-xl">
            <img src="https://images.unsplash.com/photo-1541888946425-d81bb19240f5?w=600&q=75&auto=format" alt="Construction technology" loading="lazy" decoding="async" class="w-full h-auto hover:scale-105 transition-transform duration-500" />
          </div>
        </div>
      </div>
    </section>

    <section class="py-20 bg-gray-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Our Values</h2>
          <p class="text-lg text-gray-600 max-w-2xl mx-auto">
            These core values guide everything we do at Climax Innovation.
          </p>
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
          {values.map((value) => (
            <div class="bg-white rounded-2xl p-6 text-center shadow-sm">
              <div class="text-4xl mb-4">{value.icon}</div>
              <h3 class="text-xl font-semibold text-gray-900 mb-2">{value.title}</h3>
              <p class="text-gray-600">{value.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="py-20 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <p class="text-amber-500 font-semibold tracking-wide uppercase text-sm mb-4">Our Team</p>
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Meet the Experts</h2>
          <p class="text-lg text-gray-600 max-w-2xl mx-auto">
            Our dedicated team of professionals brings together expertise in construction, 
            technology, and innovation.
          </p>
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
          {team.map((member) => (
            <div class="bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-lg transition-shadow">
              <div class="aspect-square bg-gray-100">
                <img 
                  src={member.image} 
                  alt={member.name}
                  class="w-full h-full object-cover"
                />
              </div>
              <div class="p-6 text-center">
                <h3 class="text-xl font-semibold text-gray-900 mb-1">{member.name}</h3>
                <p class="text-amber-500 mb-4">{member.role}</p>
                {member.linkedin !== '#' && (
                  <a 
                    href={member.linkedin}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center text-gray-600 hover:text-amber-500 transition-colors"
                  >
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
                    </svg>
                  </a>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="py-20 bg-gray-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Our Journey</h2>
          <p class="text-lg text-gray-600 max-w-2xl mx-auto">
            From a vision to a global leader in construction technology.
          </p>
        </div>
        <div class="relative">
          {milestones.map((milestone, index) => (
            <div class="flex gap-8 mb-8 last:mb-0">
              <div class="flex flex-col items-center">
                <div class="w-16 h-16 bg-amber-500 rounded-full flex items-center justify-center text-white font-bold">
                  {milestone.year}
                </div>
                {index < milestones.length - 1 && (
                  <div class="w-0.5 h-full bg-amber-200 mt-4"></div>
                )}
              </div>
              <div class="pt-3">
                <h3 class="text-xl font-semibold text-gray-900">{milestone.title}</h3>
                <p class="text-gray-600 mt-1">{milestone.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <CTA
      title="Ready to Transform Your Projects?"
      description="Let us show you how our solutions can improve your construction operations."
    />
  </main>
  <Footer />
</Layout>
