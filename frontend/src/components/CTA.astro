---
interface Props {
  title?: string;
  description?: string;
  primaryCta?: {
    text: string;
    href: string;
  };
  secondaryCta?: {
    text: string;
    href: string;
  };
}

const {
  title = 'Ready to Transform Your Construction Projects?',
  description = 'Join hundreds of companies already using Climax Innovation to build smarter, safer, and more efficiently.',
  primaryCta = { text: 'Get Started Today', href: '/contact' },
  secondaryCta = { text: 'Learn More', href: '/services' },
} = Astro.props;
---

<section class="py-20 md:py-28 bg-white">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-gray-900 mb-6">
      {title}
    </h2>
    <p class="text-lg text-gray-600 mb-8 max-w-2xl mx-auto">
      {description}
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href={primaryCta.href}
        class="inline-flex items-center justify-center px-8 py-4 bg-blue-600 text-white rounded-lg font-semibold hover:bg-blue-700 transition-all hover:shadow-lg hover:shadow-blue-600/25"
      >
        {primaryCta.text}
        <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
      <a
        href={secondaryCta.href}
        class="inline-flex items-center justify-center px-8 py-4 border-2 border-gray-300 text-gray-700 rounded-lg font-semibold hover:border-blue-600 hover:text-blue-600 transition-colors"
      >
        {secondaryCta.text}
      </a>
    </div>
  </div>
</section>
