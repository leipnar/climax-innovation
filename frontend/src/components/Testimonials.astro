---
import type { Testimonial } from '../lib/drupal';

interface Props {
  testimonials: Testimonial[];
}

const { testimonials } = Astro.props;
---

<section class="py-20 md:py-28 relative overflow-hidden">
  <div class="absolute inset-0">
    <img 
      src="https://images.unsplash.com/photo-1541888946425-d81bb19240f5?w=1200&q=75&auto=format" 
      alt="" 
      class="w-full h-full object-cover"
      loading="lazy"
      width="1920"
      height="1080"
    />
    <div class="absolute inset-0 bg-gradient-to-br from-amber-600/95 to-amber-900/95"></div>
  </div>
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <p class="text-amber-200 font-semibold tracking-wide uppercase text-sm mb-4">
        Testimonials
      </p>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-white mb-6">
        What Our Clients Say
      </h2>
      <p class="text-lg text-amber-100">
        Trusted by construction companies worldwide to transform their operations.
      </p>
    </div>
    
    <div class="grid md:grid-cols-3 gap-6 lg:gap-8">
      {testimonials.map((testimonial) => (
        <div class="bg-white/10 backdrop-blur-sm rounded-2xl p-6 md:p-8">
          <div class="flex items-center gap-1 mb-4">
            {[...Array(5)].map(() => (
              <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <p class="text-white/90 mb-6 leading-relaxed">
            "{testimonial.content}"
          </p>
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 bg-white/20 rounded-full flex items-center justify-center">
              {testimonial.avatar ? (
                <img
                  src={testimonial.avatar}
                  alt={testimonial.name}
                  class="w-full h-full rounded-full object-cover"
                />
              ) : (
                <span class="text-white font-semibold text-lg">
                  {testimonial.name.charAt(0)}
                </span>
              )}
            </div>
            <div>
              <p class="text-white font-semibold">{testimonial.name}</p>
              <p class="text-amber-200 text-sm">{testimonial.role}, {testimonial.company}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
